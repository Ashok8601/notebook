import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.preprocessing import LabelEncoder
from sklearn.naive_bayes import MultinomialNB
from sklearn.metrics import classification_report, accuracy_score
import pickle

# ---------------- 1️⃣ Load CSV ---------------- #
data = pd.read_csv("labelled.csv")  # CSV folder me hona chahiye
print("Data Loaded:", data.shape)
print(data.head())

# Optional: agar aapke paas title + content dono ho
# data['text'] = data['title'] + " " + data['content']
# X = data['text']

# Current example: use keyword as text
X = data['keyword']
y = data['category']

# ---------------- 2️⃣ Label Encoding ---------------- #
le = LabelEncoder()
y_encoded = le.fit_transform(y)

# Save label encoder for later prediction
with open("label_encoder.pkl", "wb") as f:
    pickle.dump(le, f)

# ---------------- 3️⃣ Train-Test Split ---------------- #
X_train, X_test, y_train, y_test = train_test_split(
    X, y_encoded, test_size=0.2, random_state=42
)

# ---------------- 4️⃣ Text Vectorization ---------------- #
vectorizer = TfidfVectorizer()
X_train_vec = vectorizer.fit_transform(X_train)
X_test_vec = vectorizer.transform(X_test)

# Save vectorizer for later use
with open("tfidf_vectorizer.pkl", "wb") as f:
    pickle.dump(vectorizer, f)

# ---------------- 5️⃣ Train Model ---------------- #
model = MultinomialNB()
model.fit(X_train_vec, y_train)

# Save trained model
with open("category_model.pkl", "wb") as f:
    pickle.dump(model, f)

# ---------------- 6️⃣ Evaluate Model ---------------- #
y_pred = model.predict(X_test_vec)
print("Accuracy:", accuracy_score(y_test, y_pred))
print("\nClassification Report:\n", classification_report(
    y_test, y_pred, target_names=le.classes_
))

# ---------------- 7️⃣ Prediction Function ---------------- #
def predict_category(text):
    """Predict category for a new notebook title/content"""
    # Load saved objects (optional if already in memory)
    # with open("tfidf_vectorizer.pkl", "rb") as f:
    #     vectorizer = pickle.load(f)
    # with open("category_model.pkl", "rb") as f:
    #     model = pickle.load(f)
    # with open("label_encoder.pkl", "rb") as f:
    #     le = pickle.load(f)
    
    vec = vectorizer.transform([text])
    pred = model.predict(vec)
    category = le.inverse_transform(pred)
    return category[0]

# ---------------- 8️⃣ Example Usage ---------------- #
sample_note = "Python function to sort array"
predicted_category = predict_category(sample_note)
print("Sample Note:", sample_note)
print("Predicted Category:", predicted_category)